{
  "manifest_version": 3,
  "name": "Altreurl",
  "description": "Manage local debugging redirects and request header overrides.",
  "version": "1.12.0",
  "icons": {
    "16": "src/shared/imgs/favicons/v2/Altreurl_16.png",
    "32": "src/shared/imgs/favicons/v2/Altreurl_32.png",
    "48": "src/shared/imgs/favicons/v2/Altreurl_48.png",
    "64": "src/shared/imgs/favicons/v2/Altreurl_64.png",
    "128": "src/shared/imgs/favicons/v2/Altreurl_128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Altreurl",
    "default_icon": {
      "16": "src/shared/imgs/favicons/v2/Altreurl_16.png",
      "32": "src/shared/imgs/favicons/v2/Altreurl_32.png",
      "48": "src/shared/imgs/favicons/v2/Altreurl_48.png",
      "64": "src/shared/imgs/favicons/v2/Altreurl_64.png",
      "128": "src/shared/imgs/favicons/v2/Altreurl_128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies",
    "scripting",
    "tabs",
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
